# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Auth.js v5
AUTH_URL="http://localhost:3000"
AUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"

# Google OAuth (Auth.js v5 convention)
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# GitHub OAuth (Auth.js v5 convention)
AUTH_GITHUB_ID="your-github-client-id"
AUTH_GITHUB_SECRET="your-github-client-secret"

# Upstash Redis
UPSTASH_REDIS_REST_URL="your-upstash-redis-url"
UPSTASH_REDIS_REST_TOKEN="your-upstash-redis-token"

# Admin emails (comma-separated)
ADMIN_EMAILS="admin@example.com"

# Game Timer Configuration (seconds)
# Easy mode: 30 seconds, Medium mode: 20 seconds, Hard mode: 15 seconds
# Note: Must use NEXT_PUBLIC_ prefix for client-side access
NEXT_PUBLIC_TURN_TIMER_EASY=30
NEXT_PUBLIC_TURN_TIMER_MEDIUM=20
NEXT_PUBLIC_TURN_TIMER_HARD=15

# Bot Thinking Time Configuration (seconds)
# Easy mode: 2 seconds, Medium mode: 3 seconds, Hard mode: 4 seconds
# Note: Must use NEXT_PUBLIC_ prefix for client-side access
NEXT_PUBLIC_BOT_THINKING_EASY=2
NEXT_PUBLIC_BOT_THINKING_MEDIUM=3
NEXT_PUBLIC_BOT_THINKING_HARD=4
